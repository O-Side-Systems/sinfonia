---
# Generated by `setup-workflow` skill.
# Edit freely — Sinfonia will reload on save.

tracker:
  kind: {{ tracker.kind }}
  api_key: ${{ tracker.api_key_env }}
  project_slug: {{ tracker.project_slug }}
{% if tracker.endpoint %}  endpoint: {{ tracker.endpoint }}
{% endif %}{% if tracker.email %}  email: {{ tracker.email }}
{% endif %}  active_states:
{% for s in tracker.active_states %}    - "{{ s }}"
{% endfor %}  terminal_states:
{% for s in tracker.terminal_states %}    - "{{ s }}"
{% endfor %}
agent:
  provider: {{ agent.provider }}
{% if llm %}
llm:
  api_key: ${{ llm.api_key_env }}
  model: {{ llm.model }}
{% endif %}
workspace:
  root: {{ workspace.root }}

{% if hooks %}hooks:
  after_create:
    - "{{ hooks.after_create }}"
  before_run:
    - "{{ hooks.before_run }}"
{% endif %}---

You are working on issue {{ "{{ issue.identifier }}" }}: {{ "{{ issue.title }}" }}.

{{ "{% if issue.description %}{{ issue.description }}{% endif %}" }}
