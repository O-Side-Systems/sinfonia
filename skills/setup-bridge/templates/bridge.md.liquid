---
# Generated by `setup-bridge` skill.
# See BRIDGE.example.md in the repo root for the full reference + comments.

webhook:
  secret: ${{ webhook.secret_env }}
  path: /webhook
{% if topology == "sibling" %}  bind: 127.0.0.1
  port: {{ webhook.port }}
{% elsif topology == "standalone" %}  bind: 0.0.0.0
  port: {{ webhook.port }}
  public_url: {{ webhook.public_url }}
{% else %}  # Actions-only topology — the bridge is invoked from a workflow.
  bind: 127.0.0.1
  port: {{ webhook.port }}
{% endif %}

server:
  bind: {% if topology == "standalone" %}0.0.0.0{% else %}127.0.0.1{% endif %}
  port: {{ server.port }}
{% if topology == "standalone" %}  public_url: {{ webhook.public_url }}
{% endif %}

github:
{% if github.mode == "pat" %}  auth:
    mode: pat
    token: $GITHUB_TOKEN
{% else %}  auth:
    mode: app
    app_id: $BRIDGE_APP_ID
    installation_id: $BRIDGE_APP_INSTALLATION_ID
    private_key_path: $BRIDGE_APP_PRIVATE_KEY_PATH
{% endif %}
tracker:
  kind: {{ tracker.kind }}
  api_key: ${{ tracker.api_key_env }}
  project_slug: {{ tracker.project_slug }}
{% if tracker.endpoint %}  endpoint: {{ tracker.endpoint }}
{% endif %}{% if tracker.email %}  email: {{ tracker.email }}
{% endif %}
feedback_loop:
  max_attempts: 5
  budget_exceeded_state: "Needs Fixes"
  failure_categories:
    lint: ["eslint", "ruff", "rubocop", "clippy"]
    unit_test: ["jest", "pytest", "cargo test"]
    e2e: ["playwright", "cypress", "selenium"]
    build: ["webpack", "vite", "tsc"]

# Per-ticket budget caps. Both fields default to "no cap"; set them to
# enable budget enforcement (Phase 3 §11.6.12).
# bridge:
#   max_tokens_per_ticket: 1_000_000
#   max_cost_usd_per_ticket: 25.00
---

# This file is parsed by `sinfonia-bridge` on startup. Run
# `sinfonia-bridge BRIDGE.md --check` after editing.
