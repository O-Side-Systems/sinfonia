# Copy to .env and fill in. Already gitignored.

# Linear personal API key (read+write), scoped to the throwaway test project.
LINEAR_API_KEY=lin_api_...

# GitHub token for `gh` + git push from sinfonia's child agents.
# Needs: repo (read/write), workflow if PR triggers Actions.
GH_TOKEN=ghp_...

# Git identity for commits made by the agent inside the container.
GIT_USER_NAME=Brett Lee
GIT_USER_EMAIL=brett.lee@oside.systems

# Optional — override the default debug log filter.
# RUST_LOG=sinfonia=info,orchestrator=debug
